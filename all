<br/>

<asp:TextBox ID="txtPrime" runat="server"></asp:TextBox>
<asp:Button ID="btnPrime" runat="server" Text="Prime" OnClick="btnPrime_Click"/>
<asp:Label ID="lblPrimeResult" runat="server"></asp:Label>

<br/>

<asp:TextBox ID="txtChar" runat="server"></asp:TextBox>
<asp:Button ID="btnChar" runat="server" Text="Check" OnClick="btnChar_Click"/>
<asp:Label ID="lblCharResult" runat="server"></asp:Label>

<br/>

<asp:TextBox ID="txtReverse" runat="server"></asp:TextBox>
<asp:Button ID="btnReverse" runat="server" Text="Rev" OnClick="btnReverse_Click"/>
<asp:Label ID="lblReverseResult" runat="server"></asp:Label>

</form>

Login.aspx.cs
using System;
using System.Web.UI;

public partial class Login:Page
{

protected void btnFib_Click(object sender,EventArgs e)
{
int n=int.Parse(txtFib.Text),a=0,b=1,c;string r="0 1 ";
for(int i=3;i<=n;i++){c=a+b;r+=c+" ";a=b;b=c;}
lblFibResult.Text=r;
}

protected void btnPrime_Click(object sender,EventArgs e)
{
int n=int.Parse(txtPrime.Text),i;
for(i=2;i<n;i++)if(n%i==0)break;
lblPrimeResult.Text=i==n?"Prime":"Not";
}

protected void btnChar_Click(object sender,EventArgs e)
{
char c=char.Parse(txtChar.Text.ToLower());
lblCharResult.Text="aeiou".Contains(c)?"Vowel":"Cons";
}

protected void btnReverse_Click(object sender,EventArgs e)
{
int n=int.Parse(txtReverse.Text),r=0;
while(n>0){r=r*10+n%10;n/=10;}
lblReverseResult.Text=r.ToString();
}
}

