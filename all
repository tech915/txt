Login.aspx.cs
static Dictionary<string, string> phoneBook = new Dictionary<string, string>();

protected void btnSave_Click(object sender, EventArgs e)
{
    string name = txtName.Text;
    string phone = txtPhone.Text;

    phoneBook[name] = phone;

    lblPhoneBookResult.Text = "Saved: " + name + " - " + phone;
}

protected void btnPythagoras_Click(object sender, EventArgs e)
{
    double a = double.Parse(txtA.Text);
    double b = double.Parse(txtB.Text);

    double result = Math.Sqrt(a * a + b * b);

    lblPythagorasResult.Text = "Hypotenuse = " + result;
}

