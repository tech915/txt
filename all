Login.aspx.cs
using System;
using System.Web.UI;

public partial class Login:Page
{

protected void btnFact_Click(object s,EventArgs e)
{
int n=int.Parse(txtFact.Text),f=1;
for(int i=1;i<=n;i++)f*=i;
lblFact.Text=f.ToString();
}

protected void btnMoney_Click(object s,EventArgs e)
{
double a=double.Parse(txtMoney.Text);
lblMoney.Text=ddlMoney.SelectedIndex==0?(a/83).ToString():(a*83).ToString();
}

protected void btnQuad_Click(object s,EventArgs e)
{
double a=double.Parse(txtA.Text),b=double.Parse(txtB.Text),c=double.Parse(txtC.Text);
double d=b*b-4*a*c;
if(d<0)lblQuad.Text="No";
else lblQuad.Text=(( -b+Math.Sqrt(d))/(2*a))+" "+((-b-Math.Sqrt(d))/(2*a));
}

protected void btnTemp_Click(object s,EventArgs e)
{
double t=double.Parse(txtTemp.Text);
lblTemp.Text=ddlTemp.SelectedIndex==0?((t*9/5)+32).ToString():((t-32)*5/9).ToString();
}
}

