Login.aspx.cs
protected void btnFib_Click(object sender, EventArgs e)
{
    int n = int.Parse(txtFib.Text);
    int a = 0, b = 1, c;
    string result = a + " " + b + " ";

    for (int i = 3; i <= n; i++)
    {
        c = a + b;
        result += c + " ";
        a = b;
        b = c;
    }

    lblFibResult.Text = result;
}

protected void btnPrime_Click(object sender, EventArgs e)
{
    int num = int.Parse(txtPrime.Text);
    bool prime = true;

    for (int i = 2; i < num; i++)
    {
        if (num % i == 0)
        {
            prime = false;
            break;
        }
    }

    lblPrimeResult.Text = prime ? "Prime" : "Not Prime";
}

protected void btnChar_Click(object sender, EventArgs e)
{
    char ch = char.Parse(txtChar.Text.ToLower());

    if ("aeiou".Contains(ch))
        lblCharResult.Text = "Vowel";
    else
        lblCharResult.Text = "Consonant";
}

protected void btnReverse_Click(object sender, EventArgs e)
{
    int num = int.Parse(txtReverse.Text);
    int rev = 0;

    while (num > 0)
    {
        rev = rev * 10 + num % 10;
        num /= 10;
    }

    lblReverseResult.Text = rev.ToString();
}

